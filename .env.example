# Database
DATABASE_URL=./hum.db

# Shared media storage (used by content-engine and dashboard)
MEDIA_STORAGE_PATH=./media

# OpenAI
OPENAI_API_KEY=

# fal.ai (FLUX image generation)
FAL_API_KEY=

# Ayrshare (social media posting)
AYRSHARE_API_KEY=

# Stripe
STRIPE_SECRET_KEY=

# Google Business Profile
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Integration mock mode (set to "true" for development without real APIs)
HUM_MOCK_INTEGRATIONS=

# Stripe webhook secret (for verifying webhook signatures)
STRIPE_WEBHOOK_SECRET=
